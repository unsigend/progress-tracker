{
    "compilerOptions": {
        "target": "ES2023",
        "jsx": "preserve",
        "module": "ESNext",
        "allowJs": true,
        "outDir": "./dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true
    },
    "exclude": ["node_modules", "dist", "client", "backup"]
}
