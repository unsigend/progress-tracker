{
    "compilerOptions": {
        "target": "ES2023",
        "module": "CommonJS",
        "allowJs": true,
        "outDir": "./dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@root/*": ["../*"]
        }
    },
    "ts-node": {
        "esm": false
    },
    "exclude": ["node_modules", "dist", "client", "backup"]
}
